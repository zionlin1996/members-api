# Server
NODE_ENV=development
PORT=3000
# Comma-separated browser origins allowed to send credentialed requests
CORS_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/members_db

# JWT (refresh tokens are internal HS256; access + ID tokens are RS256 — see OIDC)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OIDC issuer
# OIDC_ISSUER: public base URL of this API (appears as `iss` and in discovery).
# OIDC_PRIVATE_KEY: RSA private key, PEM or base64-encoded PEM. If unset, an
#   ephemeral key is generated at boot (dev only — tokens reset on restart).
#   Generate one with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | base64
# OIDC_CLIENT_ID: audience (`aud`) of issued ID tokens.
OIDC_ISSUER=http://localhost:3000
OIDC_CLIENT_ID=members-web
OIDC_PRIVATE_KEY=
EMAIL_DOMAIN=yangfrenz.club

# Bcrypt
BCRYPT_ROUNDS=12

# WebAuthn / Passkey
WEBAUTHN_RP_ID=yangfrenz.club
WEBAUTHN_RP_NAME=YangFrenz
WEBAUTHN_ORIGIN=https://yangfrenz.club

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yangfrenz.club/auth/login/google/callback

# Telegram OAuth
TELEGRAM_BOT_TOKEN=

# Admin API
ADMIN_API_KEY=change_me_admin_api_key

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  UNVERIFIED
  ACTIVE
  SUSPENDED
}

enum CredentialType {
  PASSWORD
  PASSKEY
  GOOGLE
  TELEGRAM
}

model Member {
  id            String         @id @default(uuid())
  displayName   String
  username      String         @unique
  status        MemberStatus   @default(UNVERIFIED)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  credentials   Credential[]
}

model Credential {
  id           String         @id @default(uuid())
  memberId     String
  member       Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type         CredentialType
  credentialId String?        @unique
  providerId   String?
  meta         Json
  createdAt    DateTime       @default(now())

  @@unique([type, providerId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PendingChallenge {
  id        String   @id @default(uuid())
  challenge String
  context   Json
  expiresAt DateTime
  createdAt DateTime @default(now())
}

{
  "name": "members-api",
  "version": "1.0.0",
  "description": "Member management API with JWT auth",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:oidc": "node tests/integration/oidc-flow.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "yarn lint-staged"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md}": "prettier --write"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@simplewebauthn/server": "^13.3.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "oidc-provider": "^9.8.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.19",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15",
    "nodemon": "^3.1.7",
    "prettier": "^3.8.4",
    "prisma": "^5.22.0",
    "simple-git-hooks": "^2.13.1",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "packageManager": "yarn@1.22.22"
}

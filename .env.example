# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/members_db

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# WebAuthn / Passkey
WEBAUTHN_RP_ID=yangfrenz.club
WEBAUTHN_RP_NAME=YangFrenz
WEBAUTHN_ORIGIN=https://yangfrenz.club

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://yangfrenz.club/auth/login/google/callback

# Telegram OAuth
TELEGRAM_BOT_TOKEN=

# Admin API
ADMIN_API_KEY=change_me_admin_api_key

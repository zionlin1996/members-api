# Server
NODE_ENV=development
PORT=3000

# Domain topology — production sets just these three; the API derives every
# public hostname from them:
#   CORS origin / WebAuthn origin = https://{APP_SUBDOMAIN}.{DOMAIN}
#   OIDC issuer                   = https://{API_SUBDOMAIN}.{DOMAIN}
#   OIDC audience (client id)     = {APP_SUBDOMAIN}.{DOMAIN}
#   WebAuthn RP ID / email domain = {DOMAIN}
DOMAIN=yangfrenz.club
API_SUBDOMAIN=members-api
APP_SUBDOMAIN=members

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/members_db

# JWT (refresh tokens are internal HS256; access + ID tokens are RS256 — see OIDC)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OIDC signing key — issuer URL, audience (client id) and email domain are all
# derived from the domain topology above; only the signing key is set here.
# RSA private key, PEM or base64-encoded PEM. If unset, an ephemeral key is
# generated at boot (dev only — tokens reset on restart). Generate one with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 | base64 | tr -d '\n'
OIDC_PRIVATE_KEY=

# OIDC Authorization Server (Phase 3 — third-party clients via Auth Code + PKCE).
# OIDC_COOKIE_KEYS: comma-separated secrets used to sign the provider's
#   interaction/session cookies (rotate by prepending a new key). Required.
# OIDC_API_RESOURCE: audience of third-party JWT access tokens. MUST differ from
#   OIDC_ISSUER so scoped third-party tokens can't reach first-party endpoints
#   (derived from the API origin + /api when unset).
# OIDC_ADAPTER: persistence adapter — 'prisma' (default) or 'memory' (tests only).
OIDC_COOKIE_KEYS=change_me_cookie_key_1,change_me_cookie_key_2
# OIDC_API_RESOURCE=https://members-api.yangfrenz.club/api
# OIDC_ADAPTER=prisma

# Bcrypt
BCRYPT_ROUNDS=12

# WebAuthn / Passkey — RP ID and origin are derived from the domain topology;
# only the human-readable name is set here.
WEBAUTHN_RP_NAME=YangFrenz

# Google OAuth. The callback URL is derived from the API base URL
# ({API_BASE}/auth/google/callback) — set only the client id + secret. Register
# the derived URL under your OAuth client's "Authorized redirect URIs" (Google
# Cloud Console → APIs & Services → Credentials → your Web client):
#   prod → https://members-api.yangfrenz.club/auth/google/callback
#   dev  → http://localhost:3000/auth/google/callback   (follows OIDC_ISSUER)
# NOTE: localhost goes in "Authorized redirect URIs" (on the client), NOT in the
# consent screen's "Authorized domains" (which rejects localhost and only needs
# the prod domain, yangfrenz.club). http://localhost is exempt from Google's
# HTTPS-only redirect rule, so no tunnel/HTTPS is needed for local dev.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram OAuth
TELEGRAM_BOT_TOKEN=

# Admin API
ADMIN_API_KEY=change_me_admin_api_key

# ── Local development overrides ───────────────────────────────────────────────
# In dev the app/API run on http://localhost with ports, which can't be derived
# from a domain. Uncomment these for local development:
# OIDC_ISSUER=http://localhost:3000
# CORS_ORIGIN=http://localhost:5173
# APP_ORIGIN=http://localhost:5173   # SPA origin; where the AS redirects for login/consent
# WEBAUTHN_RP_ID=localhost
# WEBAUTHN_ORIGIN=http://localhost:5173
# (GOOGLE_CALLBACK_URL follows OIDC_ISSUER automatically — no dev override needed)
